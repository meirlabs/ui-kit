{
  "name": "@meirlabs/ui-kit",
  "version": "0.1.0",
  "description": "Dark-themed presentational component library for React",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css",
    "./compat.css": "./dist/compat.css"
  },
  "files": [
    "dist",
    "AGENTS.md"
  ],
  "sideEffects": [
    "./dist/styles.css",
    "./dist/compat.css"
  ],
  "scripts": {
    "build": "tsup && postcss src/styles/index.css -o dist/styles.css && postcss src/styles/compat.css -o dist/compat.css",
    "prepublishOnly": "npm run build",
    "dev": "concurrently \"tsup --watch\" \"postcss src/styles/index.css -o dist/styles.css --watch\" \"postcss src/styles/compat.css -o dist/compat.css --watch\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite --config preview/vite.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.3.3",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.0.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.5.0",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^10.3.3",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.3",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xmeir-dev/ui-kit.git"
  },
  "homepage": "https://github.com/xmeir-dev/ui-kit#readme",
  "bugs": "https://github.com/xmeir-dev/ui-kit/issues",
  "publishConfig": {
    "access": "public"
  }
}
